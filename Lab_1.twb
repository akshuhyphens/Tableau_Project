      <aliases enabled='yes' />
      <column caption='Review Performance Score' datatype='integer' name='[Calculation_0292221554184193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Number Of Reviews] * [Review Scores Rating]' />
      </column>
      <column caption=' Pricing Categorys' datatype='string' name='[Calculation_0292221555605506]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Price] &gt;= 300 THEN &quot;Luxury&quot;&#13;&#10;ELSEIF [Price] &gt;= 150 THEN &quot;Standard&quot;&#13;&#10;ELSE &quot;Budget&quot;&#13;&#10;END' />
      </column>
      <column caption='Review Category' datatype='string' name='[Calculation_0292221557084163]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Number Of Reviews] &gt;= 100 THEN &quot;Highly Reviewed&quot;&#13;&#10;ELSE &quot;Less Reviewed&quot;&#13;&#10;END' />
      </column>
      <column caption='Host Status' datatype='string' name='[Calculation_0292221558054916]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Host Since] &lt;= TODAY() THEN &quot;Active Host&quot;&#13;&#10;ELSE &quot;New Host&quot;&#13;&#10;END' />
      </column>
      <column caption='Price Filter Category' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_0292221560725509]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Price] &gt; [Parameters].[Parameter 0292221561688070] &#13;&#10;THEN &quot;above limit&quot;&#13;&#10;ELSE &quot;below limit&quot;&#13;&#10;END' />
      </column>
